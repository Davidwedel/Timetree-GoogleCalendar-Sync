# TimeTree Session Cookie (_session_id)
# To get this:
# 1. Log into TimeTree in your browser
# 2. Open DevTools (F12) -> Network tab
# 3. Click on any API request (like /api/v2/calendars)
# 4. Look at Request Headers -> Cookie header
# 5. Copy the value after "_session_id="
# Example: 4d0610c906d64780ed2a5a7ea61c3bf2
TIMETREE_SESSION_COOKIE=your_session_cookie_here

# TimeTree CSRF Token (X-CSRF-Token)
# From the same request headers, copy the X-CSRF-Token value
# This is optional but recommended for write operations
TIMETREE_CSRF_TOKEN=your_csrf_token_here

# TimeTree Calendar ID
# From your calendar URL: https://timetreeapp.com/calendars/CALENDAR_ID
TIMETREE_CALENDAR_ID=your_calendar_id_here

# Google Calendar ID (usually your email or 'primary')
GOOGLE_CALENDAR_ID=primary
